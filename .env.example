# Infizia website — environment variables (TEMPLATE)
#
# Copy this file to `.env` (or `.env.local`) and fill in the real values.
# Both `.env` and `.env.local` are git-ignored under the project's
# `.env*` rule. Never commit real credentials.
#
# See docs/CONTACT_SETUP.md for the full Zoho + reCAPTCHA setup guide.

# ── Google reCAPTCHA v3 ────────────────────────────────────────

# Server-side secret. Get a v3 key pair from
# https://www.google.com/recaptcha/admin/create — register the site
# (e.g. infizia.in + localhost for dev) and choose reCAPTCHA v3.
RECAPTCHA_SECRET_KEY=

# Client-side site key (public). Pairs with the secret above.
# Must be prefixed with NEXT_PUBLIC_ so it's exposed to the browser.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Optional. Threshold for the v3 score (0.0–1.0). Submissions below
# this score are silently dropped server-side. Default 0.5.
# RECAPTCHA_THRESHOLD=0.5

# ── Zoho Mail SMTP (required for /api/contact form delivery) ────

# Region SMTP host. Use:
#   smtp.zoho.in        for India region (most likely for infizia.in)
#   smtp.zoho.com       for US / global region
#   smtp.zoho.eu        for EU region
SMTP_HOST=smtp.zoho.in

# 465 = SSL (recommended), 587 = STARTTLS
SMTP_PORT=465

# Set to "true" for port 465, "false" for port 587.
# Defaults to true when port is 465.
SMTP_SECURE=true

# The Zoho mailbox that authenticates with SMTP.
# Must match the From address (Zoho rejects send-as for unverified domains).
SMTP_USER=sales@infizia.in

# Zoho app-specific password — NOT your Zoho account password.
# Generate from: Zoho Mail → Settings → Security → App Passwords.
SMTP_PASSWORD=

# From line shown in the email — display name + address.
MAIL_FROM="Infizia Website <sales@infizia.in>"

# Where contact form submissions land. Usually same as SMTP_USER.
MAIL_TO=sales@infizia.in

# Optional: override the Reply-To address. By default the API route
# uses the submitter's email so sales can reply directly to them.
# MAIL_REPLY_TO=sales@infizia.in
